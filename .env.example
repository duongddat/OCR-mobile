# =====================================================
# EXPO ENVIRONMENT VARIABLES - EXAMPLE TEMPLATE
# =====================================================
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env
#
# File .env KHÔNG được commit lên Git (đã có trong .gitignore)
# =====================================================

# IP hoặc Domain của Backend API
# - Dev LAN:    192.168.1.xxx  (chạy `ipconfig` để lấy IP máy)
# - Emulator:   10.0.2.2       (Android Emulator)
# - Production: api.yourdomain.com
EXPO_PUBLIC_API_HOST=192.168.1.xxx

# Port Backend (FastAPI mặc định = 8000)
EXPO_PUBLIC_API_PORT=8000

# Protocol (http hoặc https)
EXPO_PUBLIC_API_PROTOCOL=http
